# SMS (Twilio)
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your_auth_token
TWILIO_PHONE_NUMBER=+1234567890

# Gemini (model: default gemini-2.5-flash; see https://ai.google.dev/gemini-api/docs/models)
GEMINI_API_KEY=your_gemini_api_key
# GEMINI_MODEL=gemini-2.5-flash

# API.Bible (base URL: https://rest.api.bible/v1/bibles)
API_BIBLE_KEY=your_api_bible_key
# API_BIBLE_BASE_URL=https://rest.api.bible/v1/bibles

# Optional: include surrounding verses by default (true/false)
INCLUDE_CONTEXT_DEFAULT=false

# Server (for webhook URL)
PORT=3000

# AI Chat via email-to-SMS (Twilio Email API — https://www.twilio.com/docs/email/api/getting-started)
# Must match TWILIO_ACCOUNT_SID above (same Account SID for SMS and email)
SENDGRID_API_KEY=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
SENDGRID_FROM_EMAIL=chat@yourdomain.com
# SENDGRID_FROM_NAME=AI Chat
# Secret token for inbound email webhook (append ?secret=... to Inbound Parse URL)
# EMAIL_INBOUND_WEBHOOK_SECRET=your_random_secret
