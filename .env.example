# SMS (Twilio)
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your_auth_token
TWILIO_PHONE_NUMBER=+1234567890

# Gemini (model: default gemini-2.5-flash; see https://ai.google.dev/gemini-api/docs/models)
GEMINI_API_KEY=your_gemini_api_key
# GEMINI_MODEL=gemini-2.5-flash

# API.Bible (base URL: https://rest.api.bible/v1/bibles)
API_BIBLE_KEY=your_api_bible_key
# API_BIBLE_BASE_URL=https://rest.api.bible/v1/bibles

# Optional: include surrounding verses by default (true/false)
INCLUDE_CONTEXT_DEFAULT=false

# Server (for webhook URL)
PORT=3000

# AI Chat via email-to-SMS (Resend — https://resend.com/docs)
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxx
RESEND_FROM_EMAIL=chat@bible.phoenixwang.com
# RESEND_FROM_NAME=AI Chat
# Address that receives carrier reply emails (defaults to RESEND_FROM_EMAIL)
# RESEND_INBOUND_ADDRESS=chat@bible.phoenixwang.com
# Webhook signing secret from Resend dashboard (whsec_...)
RESEND_WEBHOOK_SECRET=whsec_xxxxxxxxxxxxxxxxxxxxxxxx
