# Twilio — https://www.twilio.com/docs/usage/requests-to-twilio
#
# Option A (recommended for production): API Key + Secret + Account SID
#   TWILIO_SID=SK...              API Key SID (twilio.com/console/runtime/api-keys)
#   TWILIO_CLIENT_SECRET=...      API Key Secret
#   TWILIO_ACCOUNT_SID=AC...      Account SID (required with API keys)
#   TWILIO_AUTH_TOKEN=...         Auth Token — required for inbound webhook signature validation
#                                 (https://www.twilio.com/docs/usage/webhooks/webhooks-security)
#
# Option B (local testing): Account SID + Auth Token
TWILIO_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_CLIENT_SECRET=your_auth_token
TWILIO_PHONE_NUMBER=+1234567890
# Auth Token for webhook signature validation — copy from twilio.com/console Account Dashboard.
# Must be the Auth Token (not API Key Secret, not OAuth Client Secret).
# TWILIO_AUTH_TOKEN=your_auth_token
# Exact webhook URL from Twilio Console → Phone Number → Messaging
# TWILIO_WEBHOOK_URL=https://bible.phoenixwang.com/sms/incoming
# Temporary debug only — skips X-Twilio-Signature validation (remove in production)
# TWILIO_SKIP_WEBHOOK_VALIDATION=true
#
# Legacy names also supported: TWILIO_ACCOUNT_SID, TWILIO_AUTH_TOKEN, TWILIO_API_KEY, TWILIO_API_SECRET

# Gemini (model: default gemini-2.5-flash; see https://ai.google.dev/gemini-api/docs/models)
GEMINI_API_KEY=your_gemini_api_key
# GEMINI_MODEL=gemini-2.5-flash

# API.Bible (base URL: https://rest.api.bible/v1/bibles)
API_BIBLE_KEY=your_api_bible_key
# API_BIBLE_BASE_URL=https://rest.api.bible/v1/bibles

# Optional: include surrounding verses by default (true/false)
INCLUDE_CONTEXT_DEFAULT=false

# Server (for webhook URL)
PORT=3000

# AI Chat via email-to-SMS (Resend — https://resend.com/docs)
# Outbound replies go through carrier email gateways; inbound messages arrive via Twilio SMS webhook.
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxx
RESEND_FROM_EMAIL=chat@bible.phoenixwang.com
# RESEND_FROM_NAME=AI Chat
# Address that receives carrier reply emails (defaults to RESEND_FROM_EMAIL)
# RESEND_INBOUND_ADDRESS=chat@bible.phoenixwang.com
# Webhook signing secret from Resend dashboard (whsec_...)
RESEND_WEBHOOK_SECRET=whsec_xxxxxxxxxxxxxxxxxxxxxxxx
